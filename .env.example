# Reddit — ver r/redditdev sobre 403 Blocked; PRAW usa oauth.reddit.com + UA descritivo.
# Opcional: app em reddit.com/prefs/apps → client_id + client_secret → OAuth read-only (client_credentials).
REDDIT_USERNAME=your_reddit_username
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_DEFAULT_REGION=us-east-1
DEVRADAR_S3_BUCKET=devradar-raw

# Databricks SQL Warehouse (para dashboard Silver/Gold)
DATABRICKS_HOST=dbc-xxxxxxxx-xxxx.cloud.databricks.com
DATABRICKS_TOKEN=dapiXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
DATABRICKS_WAREHOUSE_ID=xxxxxxxxxxxx
DATABRICKS_CATALOG=workspace
DATABRICKS_SCHEMA=default

# Groq API (para AI Insights — free tier: 500K tokens/dia)
GROQ_API_KEY=gsk_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
